# Docker Container Configuration
CONTAINER_NAME=protect-webui
PUBLISHED_PORT=18780
TIMEZONE=Asia/Shanghai

# WebUI Configuration
WEBUI_LOG_LEVEL=INFO
WEBUI_ONLY=true
WEBUI_AUTH_DISABLED=true

# Data Paths (host paths)
INSTANCE_ROOT=/data/nanobot/user/public
CONFIG_FILE=/data/nanobot/config.json
SKILLS_ROOT=/data/nanobot/skills
