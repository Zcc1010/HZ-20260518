# Docker image tag
IMAGE_TAG=nanobot-webui:local

# Container name
CONTAINER_NAME=nanobot-webui

# Published port (host:container)
PUBLISHED_PORT=18780

# Timezone
TIMEZONE=Asia/Shanghai

# Log level: DEBUG, INFO, WARNING, ERROR
WEBUI_LOG_LEVEL=INFO

# WebUI only mode (skip IM channels)
WEBUI_ONLY=true

# Disable authentication (set to false to enable login)
WEBUI_AUTH_DISABLED=true

# Data directory on host
INSTANCE_ROOT=./data

# Skills directory on host
SKILLS_ROOT=./skills
